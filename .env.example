# -----------------------------------------------------------------
# Exemplo de variaveis de ambiente para os docker-compose staging/prod.
# Copie para .env (staging) ou .env.prod (producao) e ajuste os valores.
# -----------------------------------------------------------------

# Profile ativo dentro do container (sempre "docker" para os ambientes Docker)
SPRING_PROFILES_ACTIVE=docker

# Banco de dados (Postgres)
DB_HOST=db
DB_PORT=5432
DB_NAME=esg
DB_USER=esg
DB_PASSWORD=esg

# JWT - troque em producao!
JWT_SECRET=troque-este-segredo-em-producao

# Porta que a aplicacao ouve DENTRO do container
APP_PORT=8080

# Porta que sera publicada no host (para diferenciar staging/prod)
HOST_APP_PORT=8080
HOST_DB_PORT=5432
